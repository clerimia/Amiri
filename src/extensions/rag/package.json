{
  "name": "amiri-rag",
  "version": "0.0.0",
  "private": true,
  "description": "Amiri RAG extension -- 知识库语义检索（dense + sparse 混合），以 Pi extension 形式加载",
  "type": "module",
  "pi": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "ingest:blog": "tsx lib/ingestor/ingest-blog.ts",
    "ingest:interview": "tsx lib/ingestor/ingest-interview.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@langchain/textsplitters": "^0.1.0",
    "@node-rs/jieba": "^2.0.1",
    "@qdrant/js-client-rest": "^1.11.0",
    "dotenv": "^16.4.5",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typebox": "1.1.38",
    "vitest": "^2.1.0"
  }
}
