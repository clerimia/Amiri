# Amiri 环境变量
#
# 用法：cp .env.example .env，填入真实值后运行 ingest 脚本 / pi。

# ---- Ark embedding（必填两项，其余有默认） ----

# Ark API 密钥。必填。
ARK_API_KEY=

# embedding 模型。必填。Amiri 用 doubao-embedding-vision（2048 维）。
ARK_EMBEDDING_MODEL=doubao-embedding-vision

# embedding endpoint。选填，留空依次回退到 ARK_BASE_URL -> 内置默认。
# 个人接入点若走 /api/coding/v3，在此填完整 URL。
ARK_EMBEDDING_URL=

# Ark 通用 base URL。选填，仅当 ARK_EMBEDDING_URL 未设时作 embedding endpoint 回退。
# 内置默认 https://ark.cn-beijing.volces.com/api/v3。
ARK_BASE_URL=

# embedding 维度。选填，默认 2048（对齐 doubao-embedding-vision）。
ARK_EMBEDDING_DIM=2048

# ---- Qdrant（选填，有默认） ----

# Qdrant 服务端地址。选填，默认 http://127.0.0.1:6333（对齐 docker-compose）。
QDRANT_URL=http://127.0.0.1:6333

# ---- 摄入脚本（选填，有默认） ----

# 博客文章源目录。选填，默认 ./Blog/source/_posts。
BLOG_POSTS_DIR=./Blog/source/_posts
